# ── Server ────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Admin Panel (CHANGE THIS!) ────────────────────
ADMIN_SECRET_KEY=change_this_to_a_strong_password

# ── Telegram Bot ──────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Firebase (optional — leave blank to use memory) ─
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── App URL ───────────────────────────────────────
APP_URL=https://your-app-name.herokuapp.com
